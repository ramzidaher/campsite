is();\n\n    // L2: Redis  shared across all Vercel instances, ~1ms hit latency\n    if (redis) {\n      try {\n        const envelope = await redis.get<CacheEnvelope<T>>(redisKey);\n        if (envelope !== null) {\n          // Backfill L1 so subsequent requests on this instance are instant\n          cache.set(key, { value: envelope.v, expiresAt: Date.now() + ttlMs });\n          return envelope.v;\n        }\n      } catch {\n        // Redis unavailable  fall through to DB without surfacing the error\n      }\n    }\n\n    // L3: DB\n    const value = await load();\n    const expiresAt = Date.now() + ttlMs;\n    cache.set(key, { value, expiresAt });\n\n    if (redis) {\n      try {\n        await redis.set(redisKey, { v: value } satisfies CacheEnvelope<T>, { ex: Math.ceil(ttlMs / 1000) });\n      } catch {\n        // Redis write failure is non-fatal; L1 still serves this instance\n      }\n    }\n\n    return value;\n  })", "is_member_call": false, "source_file": "/Users/ramzidaher/Projects/CampSite/apps/web/src/lib/cache/sharedCache.ts", "source_location": "L102"}, {"caller_nid": "cache_sharedcache_getorloadsharedcachedvalue", "callee": "set", "is_member_call": true, "source_file": "/Users/ramzidaher/Projects/CampSite/apps/web/src/lib/cache/sharedCache.ts", "source_location": "L135"}, {"caller_nid": "cache_sharedcache_getorloadsharedcachedvalue", "callee": "delete", "is_member_call": true, "source_file": "/Users/ramzidaher/Projects/CampSite/apps/web/src/lib/cache/sharedCache.ts", "source_location": "L139"}, {"caller_nid": "cache_sharedcache_redisget", "callee": "await redis.get", "is_member_call": false, "source_file": "/Users/ramzidaher/Projects/CampSite/apps/web/src/lib/cache/sharedCache.ts", "source_location": "L157"}, {"caller_nid": "cache_sharedcache_redisset", "callee": "set", "is_member_call": true, "source_file": "/Users/ramzidaher/Projects/CampSite/apps/web/src/lib/cache/sharedCache.ts", "source_location": "L167"}, {"caller_nid": "cache_sharedcache_deleterediskey", "callee": "del", "is_member_call": true, "source_file": "/Users/ramzidaher/Projects/CampSite/apps/web/src/lib/cache/sharedCache.ts", "source_location": "L177"}, {"caller_nid": "cache_sharedcache_deleterediskeysbyprefix", "callee": "scan", "is_member_call": true, "source_file": "/Users/ramzidaher/Projects/CampSite/apps/web/src/lib/cache/sharedCache.ts", "source_location": "L190"}, {"caller_nid": "cache_sharedcache_deleterediskeysbyprefix", "callee": "all", "is_member_call": true, "source_file": "/Users/ramzidaher/Projects/CampSite/apps/web/src/lib/cache/sharedCache.ts", "source_location": "L195"}, {"caller_nid": "cache_sharedcache_deleterediskeysbyprefix", "callee": "map", "is_member_call": true, "source_file": "/Users/ramzidaher/Projects/CampSite/apps/web/src/lib/cache/sharedCache.ts", "source_location": "L195"}]}