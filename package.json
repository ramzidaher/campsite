{
  "name": "campsite",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "create-super-admin": "node scripts/create-super-admin.mjs",
    "seed-demo-org": "node scripts/seed-demo-org.mjs",
    "seed-qa-full": "node scripts/seed-qa-full.mjs",
    "qa:login-csv": "node scripts/generate-qa-login-csv.mjs",
    "generate:test-checklist": "node scripts/generate-full-app-test-checklist.mjs",
    "provision:university-of-sussex-student-union": "node scripts/provision-university-of-sussex-student-union.mjs",
    "generate:ussu-password-tsv": "python3 scripts/generate-ussu-password-import-tsv.py",
    "add-platform-founder": "node scripts/add-platform-founder.mjs",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "security:secrets": "npx gitleaks@latest detect --source . --redact --no-banner",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "supabase": "npx supabase@latest",
    "supabase:db:push": "cd supabase && npx supabase@latest db push --include-all --yes",
    "supabase:functions:deploy:verify": "npx supabase@latest functions deploy staff-discount-verify",
    "supabase:functions:deploy:broadcast-notify": "npx supabase@latest functions deploy process-broadcast-notifications --no-verify-jwt",
    "supabase:functions:deploy:rota-notify": "npx supabase@latest functions deploy process-rota-notifications --no-verify-jwt"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  }
}
