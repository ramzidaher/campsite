{
  "name": "campsite",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "create-super-admin": "node scripts/create-super-admin.mjs",
    "seed-demo-org": "node scripts/seed-demo-org.mjs",
    "seed-qa-full": "node scripts/seed-qa-full.mjs",
    "qa:login-csv": "node scripts/generate-qa-login-csv.mjs",
    "generate:test-checklist": "node scripts/generate-full-app-test-checklist.mjs",
    "routes:audit": "node scripts/route-inventory-and-probe.mjs --mode all",
    "routes:inventory": "node scripts/route-inventory-and-probe.mjs --mode inventory",
    "routes:open": "node scripts/route-inventory-and-probe.mjs --mode open --openVariants preferred",
    "routes:open:allhosts": "node scripts/route-inventory-and-probe.mjs --mode open --openVariants all",
    "db:slowwatch": "node scripts/db-slowwatch.mjs --durationSec 300 --intervalSec 30 --linked true",
    "db:slowwatch:strict": "node scripts/db-slowwatch.mjs --durationSec 300 --intervalSec 20 --commandTimeoutSec 15 --commandRetries 2 --linked true",
    "loadtest:k6:multitenant": "k6 run load-tests/k6-multitenant-reliability.js",
    "loadtest:k6:multitenant:5m": "K6_SCENARIO_DURATION=5m K6_SAFE_SUMMARY_EXPORT=reports/incident/k6-summary-latest.json k6 run load-tests/k6-multitenant-reliability.js",
    "loadtest:k6:multitenant:5m:appPath": "K6_SCENARIO_DURATION=5m K6_SAFE_SUMMARY_EXPORT=reports/incident/k6-summary-app-path-latest.json k6 run load-tests/k6-multitenant-app-path.js",
    "loadtest:k6:multitenant:5m:appPathInternal": "K6_LOADTEST_INTERNAL=1 K6_SCENARIO_DURATION=5m K6_SAFE_SUMMARY_EXPORT=reports/incident/k6-summary-app-path-internal-latest.json k6 run load-tests/k6-multitenant-app-path.js",
    "loadtest:k6:multitenant:5m:parallelShell": "K6_SCENARIO_DURATION=5m K6_USE_PARALLEL_SHELL=1 K6_SAFE_SUMMARY_EXPORT=reports/incident/k6-summary-parallel-shell-latest.json k6 run load-tests/k6-multitenant-reliability.js",
    "loadtest:k6:multitenant:5m:legacyLayout": "K6_SCENARIO_DURATION=5m K6_USE_PARALLEL_SHELL=0 K6_SAFE_SUMMARY_EXPORT=reports/incident/k6-summary-legacy-layout-latest.json k6 run load-tests/k6-multitenant-reliability.js",
    "incident:report": "node scripts/incident-report.mjs --k6Summary reports/incident/k6-summary-latest.json",
    "incident:report:appPath": "node scripts/incident-report.mjs --k6Summary reports/incident/k6-summary-app-path-latest.json",
    "incident:regen-k6-tokens": "node scripts/regen-k6-token-csv.mjs",
    "provision:university-of-sussex-student-union": "node scripts/provision-university-of-sussex-student-union.mjs",
    "generate:ussu-password-tsv": "python3 scripts/generate-ussu-password-import-tsv.py",
    "add-platform-founder": "node scripts/add-platform-founder.mjs",
    "security:bank-details:rotate-key": "node scripts/rotate-bank-details-key.mjs",
    "security:medical-notes:rotate-key": "node scripts/rotate-medical-notes-key.mjs",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "security:secrets": "npx gitleaks@latest detect --source . --redact --no-banner",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "supabase": "npx supabase@latest",
    "supabase:db:push": "cd supabase && npx supabase@latest db push --include-all --yes",
    "supabase:functions:deploy:broadcast-notify": "npx supabase@latest functions deploy process-broadcast-notifications --no-verify-jwt",
    "supabase:functions:deploy:rota-notify": "npx supabase@latest functions deploy process-rota-notifications --no-verify-jwt",
    "loadtest:k6:shell": "k6 run load-tests/k6-shell-rpc.js",
    "loadtest:k6:shell:50": "k6 run --vus 50 --duration 5m load-tests/k6-shell-rpc.js",
    "loadtest:k6:shell:100": "k6 run --vus 100 --duration 5m load-tests/k6-shell-rpc.js",
    "loadtest:k6:shell:200": "k6 run --vus 200 --duration 5m load-tests/k6-shell-rpc.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "internmap": "2.0.3"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  }
}
