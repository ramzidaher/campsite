   WITH total_objects AS ( SELECT c.relkind, pg_size_pretty(SUM(pg_relation_size(c.oid))) AS size FROM pg_class c JOIN pg_namespace n ON n.oid = c.relnamespace WHERE c.relkind IN ($3, $4, $5) AND NOT n.nspname LIKE ANY($1) GROUP BY c.relkind ), cache_hit AS ( SELECT $6 AS relkind, ROUND(SUM(idx_blks_hit)::numeric / nullif(SUM(idx_blks_hit + idx_blks_read), $7), $8) AS ratio FROM pg_statio_user_indexes WHERE NOT schemaname LIKE ANY($1) UNION SELECT $9 AS relkind, /* Handle column names for both PG15 and 17 */ ROUND( ( SUM( COALESCE( (to_jsonb(s) ->> $10)::bigint, (to_jsonb(s) ->> $11)::bigint, $12 ) )::numeric / nullif( SUM( COALESCE( (to_jsonb(s) ->> $13)::bigint, (to_jsonb(s) ->> $14)::bigint, $15 ) + COALESCE( (to_jsonb(s) ->> $16)::bigint, (to_jsonb(s) ->> $17)::bigint, $18 ) ), $19 ) ), $20 ) AS ratio FROM pg_statio_user_tables s WHERE NOT schemaname LIKE ANY($1) ) SELECT pg_size_pretty(pg_database_size($2)) AS database_size, COALESCE((SELECT size FROM total_objects WHERE relkind = $21), $22) AS total_index_size, COALESCE((SELECT size FROM total_objects WHERE relkind = $23), $24) AS total_table_size, COALESCE((SELECT size FROM total_objects WHERE relkind = $25), $26) AS total_toast_size, COALESCE((SELECT (now() - stats_reset)::text FROM extensions.pg_stat_statements_info), $27) AS time_since_stats_reset, (SELECT COALESCE(ratio::text, $28) FROM cache_hit WHERE relkind = $29) AS index_hit_rate, (SELECT COALESCE(ratio::text, $30) FROM cache_hit WHERE relkind = $31) AS table_hit_rate, COALESCE((SELECT pg_size_pretty(SUM(size)) FROM pg_ls_waldir()), $32) AS wal_size                                                                                                                                                                                                                                                                                                                                                                                                                         