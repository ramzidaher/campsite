# Copy to `.env` at repo root. `apps/web/next.config.ts` merges these into `process.env` when not set in `apps/web/.env*`.
#
# Server-only (for `npm run create-super-admin`, Founder HQ user/org deletion — never expose to the browser or commit).
# Must be the "service_role" key from Supabase → Project Settings → API (not "anon" / publishable).
# SUPABASE_SERVICE_ROLE_KEY=
# Web (Next.js) — prefix with NEXT_PUBLIC_
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Public URL of the web app (invite emails, OAuth redirects). Must be listed in Supabase → Auth → Redirect URLs.
# Local: NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: set on your host (e.g. Vercel) → Environment Variables (Production), no trailing slash.
# Pick one canonical origin (apex or www) and redirect the other at the edge; both must be allowed in Supabase.
#   SITE_URL=https://camp-site.co.uk
#   NEXT_PUBLIC_SITE_URL=https://camp-site.co.uk
# Supabase → Authentication → URL configuration → Redirect URLs, add (invite + email links), e.g.:
#   https://camp-site.co.uk/auth/callback
#   https://camp-site.co.uk/auth/confirm  (optional; forwards to callback)
#   https://*.camp-site.co.uk/auth/callback   (tenant subdomains — confirm wildcard support in your project)
# Invite emails must use the template link {{ .ConfirmationURL }} so users return with token_hash (not only SiteURL).
# Ops checklist (Supabase Dashboard → Authentication): use server-side / PKCE-style email links so `/auth/callback`
# receives `code` or `token_hash`+`type` in the query string (not tokens only in the URL hash). Add
# `https://<your-app>/auth/set-password` to Redirect URLs if you allowlist paths explicitly.

# Mobile (Expo) — duplicate values with EXPO_PUBLIC_ for Metro
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Legacy JWT anon (eyJ…) or publishable key (sb_publishable_…) — same rules as web public key.
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Same public site URL as NEXT_PUBLIC_SITE_URL (no trailing slash). Enables the Privacy link on the mobile landing screen (opens {siteUrl}/privacy).
# EXPO_PUBLIC_SITE_URL=https://camp-site.co.uk
# Optional fallbacks (app.config resolves like apps/web/src/lib/supabase/env.ts)
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Optional: auth screen org card (match web tenant branding)
# EXPO_PUBLIC_ORG_SLUG=
# EXPO_PUBLIC_ORG_DISPLAY_NAME=
# EXPO_PUBLIC_ORG_HOST_LABEL=

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=

# EAS (Expo Application Services)
EAS_PROJECT_ID=

# Vercel / CI
NEXT_PUBLIC_VERCEL_ENV=development

# Use either legacy anon JWT or a publishable key from Project Settings → API (dashboard may label it "publishable").
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Google OAuth (Calendar + Sheets + interview panel events). Scope calendar.events; callback: {origin}/api/google/oauth/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Unsplash API — optional curated backgrounds on broadcast detail (https://unsplash.com/oauth/applications).
# Without this key, the app uses Lorem Picsum placeholders instead (no signup).
# UNSPLASH_ACCESS_KEY=

# Vercel Web Analytics — set to 1 only if you enabled Analytics for the project (Dashboard → Analytics).
# Omit or leave unset to avoid loading /_vercel/insights/script.js (fewer console errors when disabled or ad-blocked).
# NEXT_PUBLIC_VERCEL_ANALYTICS=1

# Google AI Studio / Gemini API — broadcast summaries. Key: https://aistudio.google.com/apikey
# Quickstart: https://ai.google.dev/gemini-api/docs/quickstart (uses GEMINI_API_KEY; we accept that too).
# Server-only; never expose as NEXT_PUBLIC_. Optional model override (default: gemini-2.0-flash).
# GOOGLE_AI_STUDIO_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_AI_STUDIO_MODEL=gemini-2.0-flash

# Supabase Edge Functions (Phase 4 — staff discount QR signing). Set via: supabase secrets set STAFF_QR_SIGNING_SECRET=...
# STAFF_QR_SIGNING_SECRET=

# HR recruitment (Phase 1) — transactional email via Resend (https://resend.com). Optional: in-app notifications work without this.
# RESEND_API_KEY=re_...
# RESEND_FROM=CampSite HR <onboarding@yourdomain.com>